# Copy this file to .env on the Linux server. Do not commit the real .env file.
# Use strong, different passwords. Avoid single quotes and newlines in MySQL passwords.
MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password
MYSQL_SYSTEM_PASSWORD=replace-with-a-strong-system-password
MYSQL_READONLY_PASSWORD=replace-with-a-strong-readonly-password

# At least 32 random characters; used to sign JWTs.
JWT_SECRET=replace-with-a-private-random-secret-at-least-32-characters

# Required for Text-to-SQL and AI result summaries.
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# The only port published from the Compose stack.
APP_PORT=8080
